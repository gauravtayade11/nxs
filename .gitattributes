# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly declare text files
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files — never diff or merge
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.zip   binary
