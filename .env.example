# Copy this file to .env and add ONE of the following API keys.
# If neither is set, the app runs in mock/demo mode automatically.

# --- Option 1: Groq (FREE, no credit card needed) ---
# Sign up at https://console.groq.com → API Keys
# Uses Llama 3.3 70b model
VITE_GROQ_API_KEY=

# --- Option 2: Anthropic Claude (best quality, $5 free credits on sign-up) ---
# Sign up at https://console.anthropic.com → API Keys
# Uses claude-opus-4-6 model
VITE_ANTHROPIC_API_KEY=
