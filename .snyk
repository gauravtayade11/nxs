# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-CODE-CLEARTEXT-TRANSMISSION:
    - '*':
        reason: 'Local CLI server — HTTP is intentional, TLS handled by reverse proxy'
        expires: 2099-01-01T00:00:00.000Z
  SNYK-CODE-PATH-TRAVERSAL:
    - '*':
        reason: >
          opts.output is the write path (user CLI flag, sanitized in runner.js).
          _injected is the file content, not the path. False positive data-flow
          trace.
        expires: 2099-01-01T00:00:00.000Z
